              <p>Elegimos la madera, la cortamos y perforamos con precisión para que cada tubo encaje perfecto.</p>
              <div style="display:flex; gap:10px; flex-wrap:wrap; margin-top:8px">
                <a class="btn" href="#galeria">Ver galería</a>
                <a class="btn primary" href="#comprar">Quiero uno</a>
              </div>
            </div>
          </article>

          <article class="card reveal delay1">
            <div class="bgimg" style="--img:url('assets/bases_lote.jpg');"></div>
            <div class="inner">
              <span class="tag">2 · TERMINACIÓN</span>
              <h3>Lijado y barniz a mano</h3>
              <p>Terminación prolija, tacto suave y presencia real en tu cocina.</p>
            </div>
          </article>

          <article class="card reveal delay2">
            <div class="bgimg" style="--img:url('assets/tubos_en_base.jpg');"></div>
            <div class="inner">
              <span class="tag">3 · LLENADO</span>
              <h3>Tubos llenados uno por uno</h3>
              <p>Corcho, pesado, etiqueta y cinta de cierre para una presentación impecable.</p>
            </div>
          </article>

          <article class="card big reveal delay2">
            <div class="bgimg" style="--img:url('assets/almacen.jpg');"></div>
            <div class="inner">
              <span class="tag">4 · CUIDADO</span>
              <h3>Almacenamiento para mantener aroma</h3>
              <p>Separados por modelo, en lugar fresco y oscuro para cuidar la calidad.</p>
            </div>
          </article>
        </div>
      </div>
    </section>

    <!-- SABORES -->
    <section id="sabores">
      <div class="wrap">
        <div class="sectionTitle">
          <h2 class="reveal">Sabores disponibles</h2>
          <p class="reveal delay1">Elegí tus condimentos y armá tu base Tileo.</p>
        </div>

        <div class="flavors">
          <div class="flavorGroup reveal">
            <h3>🌿 Hierbas <span>4</span></h3>
            <div class="chips">
              <div class="chip">Romero</div>
              <div class="chip">Tomillo</div>
              <div class="chip">Orégano</div>
              <div class="chip">Perejil</div>
            </div>
          </div>

          <div class="flavorGroup reveal delay1">
            <h3>🧄 Ajos y cebollas <span>5</span></h3>
            <div class="chips">
              <div class="chip">Ajo granulado</div>
              <div class="chip">Ajo granulado ahumado</div>
              <div class="chip">Ajo en polvo</div>
              <div class="chip">Cebolla en escamas</div>
              <div class="chip">Cebolla en escamas ahumada</div>
            </div>
          </div>

          <div class="flavorGroup reveal delay2">
            <h3>🌶 Picantes y pimentones <span>7</span></h3>
            <div class="chips">
              <div class="chip">Ají cayena</div>
              <div class="chip">Ají molido</div>
              <div class="chip">Ají molido merkén</div>
              <div class="chip">Pimentón dulce</div>
              <div class="chip">Pimentón ahumado</div>
              <div class="chip">Paprika</div>
              <div class="chip">Pimiento granulado</div>
            </div>
          </div>

          <div class="flavorGroup reveal delay3">
            <h3>🟡 Especias <span>5</span></h3>
            <div class="chips">
              <div class="chip">Cúrcuma</div>
              <div class="chip">Jengibre</div>
              <div class="chip">Pimienta blanca</div>
              <div class="chip">Pimienta negra</div>
              <div class="chip">Nuez moscada</div>
            </div>
          </div>
        </div>

        <div style="margin-top:18px; display:flex; gap:12px; flex-wrap:wrap" class="reveal">
          <a class="btn primary" id="buyFlavors" href="#">Armar mi base por WhatsApp</a>
          <a class="btn" href="https://www.instagram.com/tileo.mercedes/" target="_blank" rel="noreferrer">Ver más fotos</a>
        </div>
      </div>
    </section>

    <!-- GALERÍA -->
    <section id="galeria">
      <div class="wrap">
        <div class="sectionTitle">
          <h2 class="reveal">Galería</h2>
          <p class="reveal delay1">Minimalismo, orden y sabor. Hecho en Mercedes.</p>
        </div>

        <div class="gallery">
          <div class="shot wide reveal" style="--img:url('assets/lote_mesa.jpg');">
            <div class="label">Producción real</div>
          </div>
          <div class="shot reveal" style="--img:url('assets/close_pimenton.jpg');">
            <div class="label">Pimentón ahumado</div>
          </div>
          <div class="shot reveal delay1" style="--img:url('assets/close_curcuma.jpg');">
            <div class="label">Cúrcuma</div>
          </div>
          <div class="shot reveal delay2" style="--img:url('assets/top_tapones.jpg');">
            <div class="label">Orden Tileo</div>
          </div>
        </div>
      </div>
    </section>

    <!-- CTA FINAL -->
    <section id="comprar" class="final">
      <div class="wrap">
        <div class="finalBox reveal">
          <div>
            <h3>¿Listo para que tu cocina se vea diferente?</h3>
            <p>
              Escribinos por WhatsApp, te pasamos opciones y armás tu base con los condimentos que más usás.
            </p>
          </div>
          <div style="display:flex; gap:10px; flex-wrap:wrap">
            <a class="btn" href="https://www.instagram.com/tileo.mercedes/" target="_blank" rel="noreferrer">Instagram</a>
            <a class="btn primary" id="buyFinal" href="#">Comprar ahora</a>
          </div>
        </div>
      </div>
    </section>

    <footer>
      <div class="wrap foot">
        <div>© <span id="year"></span> Tileo</div>
        <div style="display:flex; gap:14px; flex-wrap:wrap">
          <a href="#top">Arriba</a>
          <a href="#proceso">Proceso</a>
          <a href="#sabores">Sabores</a>
          <a href="#comprar">Comprar</a>
        </div>
      </div>
    </footer>
  </main>

  <!-- Floating WhatsApp -->
  <div class="waFloat" aria-label="WhatsApp Tileo">
    <div class="waBubble">¿Armamos tu base Tileo? 👇</div>
    <a class="waBtn" id="waFloat" href="#" aria-label="Comprar por WhatsApp">
      <!-- icon -->
      <svg class="waIcon" viewBox="0 0 32 32" fill="none" aria-hidden="true">
        <path d="M16 3C9.1 3 3.5 8.3 3.5 14.8c0 2.2.7 4.3 2 6.1L4 29l8.3-1.4c1.1.3 2.4.5 3.7.5 6.9 0 12.5-5.3 12.5-11.8S22.9 3 16 3Z" stroke="#140a04" stroke-width="2"/>
        <path d="M12.7 10.6c-.3-.6-.6-.6-1-.6h-.8c-.3 0-.7.1-1 .5-.4.4-1.4 1.3-1.4 3.1s1.5 3.6 1.7 3.9c.2.3 2.9 4.6 7.1 6.3 3.5 1.4 4.2 1.1 5 .9.8-.2 2.5-1 2.8-2 .4-1 .4-1.9.3-2.1-.1-.2-.3-.3-.7-.5s-2.5-1.3-2.9-1.4c-.4-.2-.7-.2-1 .2-.3.4-1.1 1.4-1.4 1.7-.3.3-.5.3-.9.1-.4-.2-1.8-.7-3.4-2.2-1.3-1.2-2.1-2.6-2.4-3-.2-.4 0-.6.2-.8.2-.2.4-.5.6-.7.2-.2.3-.4.4-.6.1-.2.1-.5 0-.7-.1-.2-.9-2.4-1.2-3Z" fill="#140a04"/>
      </svg>
    </a>
  </div>

  <script>
    // WhatsApp config (tu número)
    const WA_NUMBER = "5491126461540";
    const WA_TEXT = encodeURIComponent("Hola! Quiero armar una base Tileo. ¿Me pasás opciones y precios?");
    const WA_LINK = `https://wa.me/${WA_NUMBER}?text=${WA_TEXT}`;

    // Set links
    ["buyTop","buyHero","buyFlavors","buyFinal","waFloat"].forEach(id=>{
      const el = document.getElementById(id);
      if(el) el.href = WA_LINK;
    });

    // Year
    document.getElementById("year").textContent = new Date().getFullYear();

    // Reveal on scroll
    const items = document.querySelectorAll(".reveal");
    const io = new IntersectionObserver((entries)=>{
      entries.forEach(e=>{
        if(e.isIntersecting) e.target.classList.add("on");
      });
    }, {threshold: 0.12});
    items.forEach(i=>{
      if(!i.classList.contains("on")) io.observe(i);
    });

    // Gentle hero zoom effect
    const heroMedia = document.querySelector(".heroMedia");
    let t = 0;
    function tick(){
      t += 0.0035;
      if(heroMedia){
        const s = 1.02 + Math.sin(t) * 0.008;
        heroMedia.style.transform = `scale(${s})`;
      }
      requestAnimationFrame(tick);
    }
    tick();
  </script>
</body>
</html>
